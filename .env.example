# Node
TZ=America/Sao_Paulo
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=muvia

# Asaas (Fase 4 - Pagamentos)
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_ACCESS_TOKEN=

# Storage/S3 (uploads de documentos e fotos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=muvia-uploads
AWS_REGION=us-east-1

# Geocodificação (Fase 2 - Localização)
GEOCODING_PROVIDER=nominatim
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
GOOGLE_MAPS_API_KEY=